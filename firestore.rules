// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isCoordinator() {
      return isAuthenticated() && getRole() == 'coordinator';
    }

    function isSupervisor() {
      return isAuthenticated() && getRole() == 'supervisor';
    }

    function isAssessor() {
      return isAuthenticated() && getRole() == 'assessor';
    }

    function studentData(studentId) {
      return get(/databases/$(database)/documents/students/$(studentId)).data;
    }

    function isAssignedSupervisor(studentId) {
      return isSupervisor() &&
        studentData(studentId).supervisorId == request.auth.uid;
    }

    function isAssignedAssessor(studentId) {
      return isAssessor() &&
        request.auth.uid in studentData(studentId).assessorIds;
    }

    // ── Users Collection ──────────────────────────────────────────────────────
    match /users/{uid} {
      // Users can read their own profile; coordinators can read all
      allow read: if isAuthenticated() && (request.auth.uid == uid || isCoordinator());
      // Only coordinator can create/update ANY user profile. Users can create/update their own profile.
      allow write: if isCoordinator() || (isAuthenticated() && request.auth.uid == uid);
    }

    // ── Students Collection ───────────────────────────────────────────────────
    match /students/{studentId} {
      // Coordinator: full access
      allow read, write: if isCoordinator();

      // Supervisor: read students assigned to them
      allow read: if isSupervisor() &&
        resource.data.supervisorId == request.auth.uid;

      // Assessor: read students where their UID is in assessorIds
      allow read: if isAssessor() &&
        request.auth.uid in resource.data.assessorIds;
    }

    // ── Supervisor Evaluations ────────────────────────────────────────────────
    match /supervisor_evaluations/{studentId} {
      // Coordinator: read all, unlock (set isLocked = false)
      allow read, create, update: if isCoordinator();

      // Supervisor: read own submission (including when doc does not exist yet)
      allow read: if isSupervisor() && (
        resource == null || resource.data.supervisorId == request.auth.uid
      );

      // Supervisor: create first submission for assigned student
      allow create: if isSupervisor() &&
        request.resource.data.supervisorId == request.auth.uid &&
        isAssignedSupervisor(studentId);

      // Supervisor: re-submit after unlock
      allow update: if isSupervisor() &&
        resource.data.supervisorId == request.auth.uid &&
        resource.data.isLocked == false;

      // Assessor: read supervisor score for recalculation (assigned students only)
      allow read: if isAssignedAssessor(studentId);
    }

    // ── Assessor Evaluations ──────────────────────────────────────────────────
    match /assessor_evaluations/{studentId}/assessors/{assessorId} {
      // Coordinator: read all, unlock
      allow read, create, update: if isCoordinator();

      // Assessor: read/write own submission (read works even when doc does not exist)
      allow read, create: if isAssessor() &&
        request.auth.uid == assessorId &&
        isAssignedAssessor(studentId);

      allow update: if isAssessor() &&
        request.auth.uid == assessorId &&
        resource.data.isLocked == false;

      // Supervisor and Assessor: read all assessor scores for recalculation (assigned students only)
      allow read: if isAssignedSupervisor(studentId) || isAssignedAssessor(studentId);
    }

    // ── Results Collection ────────────────────────────────────────────────────
    match /results/{studentId} {
      // Coordinator: full read/write (finalize, unlock)
      allow read, write: if isCoordinator();

      // Supervisor & assessor: read results for assigned students only
      allow read: if isAssignedSupervisor(studentId) ||
        isAssignedAssessor(studentId);

      // FIXED: Only coordinator can create/update results
      // (Assessor/Supervisor submissions trigger app-side calculation,
      // then coordinator writes the finalized result via server-side function)
    }
  }
}
